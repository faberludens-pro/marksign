{
  "manifest_version": 3,
  "name": "MarkSign Panel",
  "version": "1.0.0",
  "description": "Convert any webpage to clean Markdown. Click Convert, preview, copy or download — right from Chrome's side panel.",
  "homepage_url": "https://marksign.faberludens.pro",
  "author": "Faber-Ludens Pro",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_title": "Open MarkSign Panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
